# ---- Explorer APIs (Etherscan V2 unified multichain; one key works across chains) ----
# Docs: https://docs.etherscan.io/etherscan-v2
ETHERSCAN_API_KEY=

# ---- Alchemy RPC fallback (used when Etherscan free tier does not support a chain, e.g. Base) ----
# Use Alchemy HTTPS URLs so alchemy_getAssetTransfers is available.
RPC_URL_ETHEREUM=
RPC_URL_BASE=
# Server code also accepts NEXT_PUBLIC_BASE_RPC_URL for Base if you already have it.
NEXT_PUBLIC_BASE_RPC_URL=

# ---- Supabase (optional; if not set, cache + rate-limit degrade to in-memory) ----
# Project URL, e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Service role key — server-only; NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Tunables ----
REPORT_CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=20
GRAPH_MAX_DEPTH=2
GRAPH_FANOUT_PER_NODE=3

# ---- Logging: debug | info | warn | error (default info). debug = every Etherscan call + cache debug ----
LOG_LEVEL=info
