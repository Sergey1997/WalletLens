# ---- Explorer APIs (Etherscan V2 unified multichain; one key works across chains) ----
# Docs: https://docs.etherscan.io/etherscan-v2
ETHERSCAN_API_KEY=

# ---- Alchemy RPC fallback (used when Etherscan free tier does not support a chain, e.g. Base) ----
# Use Alchemy HTTPS URLs so alchemy_getAssetTransfers is available.
RPC_URL_ETHEREUM=
RPC_URL_BASE=
# Server code also accepts NEXT_PUBLIC_BASE_RPC_URL for Base if you already have it.
NEXT_PUBLIC_BASE_RPC_URL=

# ---- Supabase (optional; if not set, cache + rate-limit degrade to in-memory) ----
# Project URL, e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Anon key — used by the browser and middleware (RLS still enforced).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only; NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Admin gating ----
# Admins are stored in the database (`public.admin_users`), not via env vars.
# Bootstrap: the first signed-in user can claim admin from the top-nav button
# (or `POST /api/admin/bootstrap`) while the table is empty. After that,
# admins are managed exclusively from /admin/users.

# ---- Tunables ----
REPORT_CACHE_TTL_SECONDS=3600
RATE_LIMIT_PER_MINUTE=20
GRAPH_MAX_DEPTH=2
GRAPH_FANOUT_PER_NODE=3
# How long the in-process risk-directory cache lives before re-loading from Supabase (ms).
RISK_DIRECTORY_TTL_MS=300000

# ---- Logging: debug | info | warn | error (default info). debug = every Etherscan call + cache debug ----
LOG_LEVEL=info
